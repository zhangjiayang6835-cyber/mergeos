{
  "openapi": "3.0.3",
  "info": {
    "title": "MergeOS Scan API",
    "version": "0.1.0",
    "description": "Public API surface used by scan.mergeos.shop for explorer data, runtime status, guest wallets, and GitHub wallet linking."
  },
  "servers": [
    {
      "url": "/",
      "description": "Current Scan origin"
    },
    {
      "url": "https://scan.mergeos.shop",
      "description": "Production Scan"
    }
  ],
  "tags": [
    {
      "name": "Scan status",
      "description": "Runtime metadata used by the Scan header and explorer."
    },
    {
      "name": "Explorer data",
      "description": "Public ledger and marketplace data rendered by Scan."
    },
    {
      "name": "Scan wallet",
      "description": "Guest wallet and GitHub linking flows available from the Scan header."
    }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "tags": ["Scan status"],
        "summary": "Read Scan backend health",
        "operationId": "getScanHealth",
        "responses": {
          "200": {
            "description": "Backend is reachable.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                },
                "example": {
                  "service": "MergeOS API",
                  "version": "0.3.0",
                  "environment": "production",
                  "token_symbol": "MRG",
                  "payment_mode": "live-adapters",
                  "repo_provider": "github-private:mergeos-bounties"
                }
              }
            }
          }
        }
      }
    },
    "/api/config": {
      "get": {
        "tags": ["Scan status"],
        "summary": "Read public runtime config for Scan",
        "operationId": "getScanConfig",
        "responses": {
          "200": {
            "description": "Public runtime config consumed by the Scan client.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RuntimeConfigResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/public/ledger": {
      "get": {
        "tags": ["Explorer data"],
        "summary": "List sanitized public MRG ledger entries",
        "operationId": "listPublicLedger",
        "responses": {
          "200": {
            "description": "Public ledger entries ordered by sequence.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/LedgerEntry"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/public/marketplace": {
      "get": {
        "tags": ["Explorer data"],
        "summary": "Read public marketplace summary for Scan stats",
        "operationId": "getPublicMarketplace",
        "responses": {
          "200": {
            "description": "Aggregated public marketplace data.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MarketplaceResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/wallets": {
      "post": {
        "tags": ["Scan wallet"],
        "summary": "Create a guest MRG wallet from Scan",
        "operationId": "createScanWallet",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateWalletRequest"
              },
              "example": {
                "label": "scan guest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Guest wallet created.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateWalletResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/api/wallets/{address}": {
      "get": {
        "tags": ["Scan wallet"],
        "summary": "Read a Scan wallet summary",
        "operationId": "getScanWallet",
        "parameters": [
          {
            "name": "address",
            "in": "path",
            "required": true,
            "description": "MRG wallet address such as 0x...",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Wallet summary with ledger totals and linked accounts.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WalletSummary"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/api/auth/github": {
      "post": {
        "tags": ["Scan wallet"],
        "summary": "Complete GitHub OAuth and link it to a Scan wallet",
        "operationId": "completeScanGitHubLink",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GitHubAuthRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "GitHub account authenticated and optionally linked to the provided wallet.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    }
  },
  "components": {
    "responses": {
      "BadRequest": {
        "description": "Request is invalid or the backend rejected the operation.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource was not found.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "string"
          }
        }
      },
      "StatusResponse": {
        "type": "object",
        "required": ["service", "version", "environment", "token_symbol", "payment_mode", "repo_provider"],
        "properties": {
          "service": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "environment": {
            "type": "string"
          },
          "token_symbol": {
            "type": "string",
            "example": "MRG"
          },
          "payment_mode": {
            "type": "string"
          },
          "repo_provider": {
            "type": "string"
          }
        }
      },
      "RuntimeConfigResponse": {
        "type": "object",
        "required": [
          "environment",
          "token_symbol",
          "payment_mode",
          "repo_provider",
          "github_oauth_ready",
          "paypal_ready",
          "crypto_ready",
          "github_ready",
          "smtp_ready",
          "dev_payment_enabled",
          "admin_bootstrap"
        ],
        "properties": {
          "environment": {
            "type": "string"
          },
          "token_symbol": {
            "type": "string",
            "example": "MRG"
          },
          "payment_mode": {
            "type": "string"
          },
          "repo_provider": {
            "type": "string"
          },
          "github_oauth_ready": {
            "type": "boolean"
          },
          "github_oauth_client_id": {
            "type": "string"
          },
          "paypal_ready": {
            "type": "boolean"
          },
          "crypto_ready": {
            "type": "boolean"
          },
          "github_ready": {
            "type": "boolean"
          },
          "smtp_ready": {
            "type": "boolean"
          },
          "dev_payment_enabled": {
            "type": "boolean"
          },
          "dev_payment_code": {
            "type": "string"
          },
          "crypto_receiver": {
            "type": "string"
          },
          "crypto_asset": {
            "type": "string"
          },
          "crypto_token": {
            "type": "string"
          },
          "bounty_root": {
            "type": "string"
          },
          "upload_root": {
            "type": "string"
          },
          "admin_bootstrap": {
            "type": "boolean"
          },
          "primary_domain": {
            "type": "string"
          },
          "admin_domain": {
            "type": "string"
          },
          "scan_domain": {
            "type": "string"
          },
          "ssl_review_domains": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "LedgerEntry": {
        "type": "object",
        "required": [
          "sequence",
          "type",
          "amount_cents",
          "reference",
          "previous_hash",
          "entry_hash",
          "created_at"
        ],
        "properties": {
          "sequence": {
            "type": "integer"
          },
          "type": {
            "type": "string",
            "example": "token_mint"
          },
          "from_account": {
            "type": "string"
          },
          "to_account": {
            "type": "string"
          },
          "amount_cents": {
            "type": "integer",
            "format": "int64"
          },
          "reference": {
            "type": "string"
          },
          "previous_hash": {
            "type": "string"
          },
          "entry_hash": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MarketplaceResponse": {
        "type": "object",
        "required": ["stats", "projects", "contributors", "agents"],
        "properties": {
          "stats": {
            "$ref": "#/components/schemas/MarketplaceStats"
          },
          "projects": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MarketplaceProject"
            }
          },
          "contributors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MarketplaceContributor"
            }
          },
          "agents": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MarketplaceAgent"
            }
          }
        }
      },
      "MarketplaceStats": {
        "type": "object",
        "properties": {
          "project_count": {
            "type": "integer"
          },
          "open_task_count": {
            "type": "integer"
          },
          "accepted_task_count": {
            "type": "integer"
          },
          "ledger_entry_count": {
            "type": "integer"
          },
          "total_budget_cents": {
            "type": "integer",
            "format": "int64"
          },
          "work_pool_cents": {
            "type": "integer",
            "format": "int64"
          },
          "token_symbol": {
            "type": "string",
            "example": "MRG"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MarketplaceProject": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "brief": {
            "type": "string"
          },
          "site_type": {
            "type": "string"
          },
          "package_tier": {
            "type": "string"
          },
          "timeline": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "client_display_name": {
            "type": "string"
          },
          "bounty_repo_name": {
            "type": "string"
          },
          "repo_provider": {
            "type": "string"
          },
          "repo_url": {
            "type": "string"
          },
          "budget_cents": {
            "type": "integer",
            "format": "int64"
          },
          "work_pool_cents": {
            "type": "integer",
            "format": "int64"
          },
          "task_count": {
            "type": "integer"
          },
          "open_task_count": {
            "type": "integer"
          },
          "accepted_task_count": {
            "type": "integer"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MarketplaceContributor": {
        "type": "object",
        "properties": {
          "worker_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "agent_type": {
            "type": "string"
          },
          "task_count": {
            "type": "integer"
          },
          "earned_cents": {
            "type": "integer",
            "format": "int64"
          },
          "last_paid_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MarketplaceAgent": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "worker_kind": {
            "type": "string"
          },
          "task_count": {
            "type": "integer"
          },
          "open_task_count": {
            "type": "integer"
          },
          "budget_cents": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "CreateWalletRequest": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string"
          }
        }
      },
      "CreateWalletResponse": {
        "type": "object",
        "required": ["address", "recovery_code", "wallet"],
        "properties": {
          "address": {
            "type": "string"
          },
          "recovery_code": {
            "type": "string"
          },
          "wallet": {
            "$ref": "#/components/schemas/WalletSummary"
          }
        }
      },
      "WalletSummary": {
        "type": "object",
        "required": [
          "address",
          "account",
          "balance_cents",
          "received_cents",
          "sent_cents",
          "transaction_count",
          "linked_accounts",
          "owner_linked",
          "created_at"
        ],
        "properties": {
          "address": {
            "type": "string"
          },
          "account": {
            "type": "string",
            "example": "0x1234..."
          },
          "balance_cents": {
            "type": "integer",
            "format": "int64"
          },
          "received_cents": {
            "type": "integer",
            "format": "int64"
          },
          "sent_cents": {
            "type": "integer",
            "format": "int64"
          },
          "transaction_count": {
            "type": "integer"
          },
          "linked_accounts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "github_username": {
            "type": "string"
          },
          "owner_linked": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "linked_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "GitHubAuthRequest": {
        "type": "object",
        "required": ["code", "redirect_uri"],
        "properties": {
          "code": {
            "type": "string",
            "description": "OAuth code returned by GitHub."
          },
          "redirect_uri": {
            "type": "string",
            "format": "uri"
          },
          "wallet_address": {
            "type": "string"
          },
          "recovery_code": {
            "type": "string"
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "required": ["token", "user"],
        "properties": {
          "token": {
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/PublicUser"
          }
        }
      },
      "PublicUser": {
        "type": "object",
        "required": ["id", "name", "company_name", "email", "role", "created_at"],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "company_name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "role": {
            "type": "string"
          },
          "wallet_address": {
            "type": "string"
          },
          "github_username": {
            "type": "string"
          },
          "github_avatar_url": {
            "type": "string",
            "format": "uri"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "last_login_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
