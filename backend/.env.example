PORT=8080
MERGEOS_ENV=local
# PostgreSQL primary storage. Leave empty only for legacy JSON-file development.
DATABASE_URL=
# Legacy JSON state import path. If DATABASE_URL is set and Postgres is empty,
# this file is imported once during startup.
MERGEOS_STATE_PATH=data/mergeos-state.json
TOKEN_SYMBOL=MRG
PLATFORM_FEE_BPS=1000

# Local verifier for development.
DEV_PAYMENT_ENABLED=true
DEV_PAYMENT_CODE=LOCAL-PAID

# Admin access. If no admin exists, the first registered user is promoted by default.
ADMIN_AUTO_PROMOTE_FIRST_USER=true
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=GoldOne123
ADMIN_NAME=MergeOS Admin
ADMIN_COMPANY_NAME=MergeOS

# PayPal Orders v2. Use sandbox for testing, live for production.
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# EVM crypto verifier.
# CRYPTO_ASSET=native requires CRYPTO_WEI_PER_USD_CENT.
# CRYPTO_ASSET=erc20 verifies Transfer logs to CRYPTO_RECEIVER.
CRYPTO_RPC_URL=
CRYPTO_RECEIVER=
CRYPTO_ASSET=erc20
CRYPTO_TOKEN_CONTRACT=
CRYPTO_TOKEN_DECIMALS=6
CRYPTO_WEI_PER_USD_CENT=
CRYPTO_MIN_CONFIRMATIONS=1

# GitHub private child bounty repos.
GITHUB_TOKEN=
GITHUB_OWNER=mergeos-bounties
GITHUB_OWNER_TYPE=org
BOUNTY_ROOT=../bounties
UPLOAD_ROOT=data/uploads

# SSL review job for production domains shown in Admin.
PRIMARY_DOMAIN=mergeos.shop
ADMIN_DOMAIN=uta.mergeos.shop
SSL_REVIEW_ENABLED=true
SSL_REVIEW_DOMAINS=mergeos.shop,uta.mergeos.shop
SSL_REVIEW_INTERVAL_MINUTES=360
SSL_EXPIRY_WARN_DAYS=14

# Customer email notifications.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@mergeos.local
